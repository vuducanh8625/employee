<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_employee_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_employee_manager" model="res.groups">
            <field name="name">Quản lý</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_employee_user" model="res.groups">
            <field name="name">Nhân viên</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
    <!-- Nhân viên: chỉ xem record của bản thân -->
    <record id="employee_personal_rule" model="ir.rule">
        <field name="name">Personal Employee</field>
        <field ref="model_employee" name="model_id"/>
        <field name="domain_force">[('user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('employee.group_employee_user'))]"/>
    </record>

    <!-- Manager: xem nhân viên cùng phòng ban -->
    <record id="employee_department_rule" model="ir.rule">
        <field name="name">Department Employees</field>
        <field ref="model_employee" name="model_id"/>
        <field name="domain_force">[('department_id.employee_ids.user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('employee.group_employee_manager'))]"/>
    </record>

    <!-- Admin: xem tất cả -->
    <record id="employee_see_all_rule" model="ir.rule">
        <field name="name">All Employees</field>
        <field ref="model_employee" name="model_id"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('employee.group_employee_admin'))]"/>
    </record>

</odoo>