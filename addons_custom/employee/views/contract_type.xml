<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_contract_type_list" model="ir.ui.view">
        <field name="name">contract.type.list</field>
        <field name="model">contract.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="default_duration"/>
            </list>
        </field>
    </record>

    <record id="view_contract_type_form" model="ir.ui.view">
        <field name="name">contract.type.form</field>
        <field name="model">contract.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="default_duration"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_contract_type" model="ir.actions.act_window">
        <field name="name">Loại hợp đồng</field>
        <field name="res_model">contract.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>