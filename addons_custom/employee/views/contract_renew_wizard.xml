<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_contract_renew_wizard_form" model="ir.ui.view">
        <field name="name">contract.renew.wizard.form</field>
        <field name="model">contract.renew.wizard</field>
        <field name="arch" type="xml">
            <form string="Gia hạn hợp đồng">
                <group>
                    <field name="contract_id" invisible="1"/>
                    <field name="new_start_date"/>
                    <field name="new_end_date"/>
                    <field name="new_salary"/>
                </group>
                <footer>
                    <button string="Xác nhận gia hạn"
                            name="action_confirm_renew"
                            type="object"
                            class="btn-primary"/>
                    <button string="Hủy" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_contract_renew_wizard" model="ir.actions.act_window">
        <field name="name">Gia hạn hợp đồng</field>
        <field name="res_model">contract.renew.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>