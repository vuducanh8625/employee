<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Action còn thiếu mà menu.xml đang gọi tới (menu "Reports").
         File MỚI hoàn toàn, không sửa employee_report.xml hay menu.xml.
         Dùng view mặc định (không khai báo arch riêng) nên không phụ
         thuộc field cụ thể nào của model employee -> chắc chắn không lỗi.
         ============================================================ -->
    <record id="action_employee_report" model="ir.actions.act_window">
        <field name="name">Employee Reports</field>
        <field name="res_model">employee</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>

</odoo>