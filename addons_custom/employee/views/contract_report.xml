<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= ACTION REPORT ================= -->
    <record id="action_report_contract" model="ir.actions.report">
        <field name="name">In hợp đồng lao động</field>
        <field name="model">contract</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">employee.report_contract_document</field>
        <field name="report_file">employee.report_contract_document</field>
        <field name="print_report_name">'Hop_dong_%s' % (object.code or 'moi')</field>
        <field name="binding_model_id" ref="model_contract"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ================= TEMPLATE QWEB ================= -->
    <template id="report_contract_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Noto Sans', 'DejaVu Sans', Arial, sans-serif;">

                        <h2 class="text-center">HỢP ĐỒNG LAO ĐỘNG</h2>
                        <p class="text-center text-muted">
                            Mã hợp đồng: <strong t-field="doc.code"/>
                        </p>

                        <div class="row mt32 mb32">
                            <div class="col-6">
                                <strong>Nhân viên:</strong>
                                <span t-field="doc.employee_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Loại hợp đồng:</strong>
                                <span t-field="doc.contract_type_id.name"/>
                            </div>
                        </div>

                        <div class="row mb32">
                            <div class="col-6">
                                <strong>Ngày bắt đầu:</strong>
                                <span t-field="doc.start_date"/>
                            </div>
                            <div class="col-6">
                                <strong>Ngày kết thúc:</strong>
                                <span t-field="doc.end_date"/>
                            </div>
                        </div>

                        <h4>Lương và phụ cấp</h4>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Khoản mục</th>
                                    <th class="text-end">Số tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Lương cơ bản</td>
                                    <td class="text-end">
                                        <span t-field="doc.salary"/>
                                    </td>
                                </tr>
                                <tr t-foreach="doc.allowance_ids" t-as="allowance">
                                    <td>
                                        <span t-field="allowance.name"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="allowance.amount"/>
                                    </td>
                                </tr>
                                <tr class="fw-bold">
                                    <td>Tổng lương</td>
                                    <td class="text-end">
                                        <span t-field="doc.total_salary"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="row mt64">
                            <div class="col-6 text-center">
                                <strong>Người lao động</strong>
                                <p class="text-muted">(Ký, ghi rõ họ tên)</p>
                            </div>
                            <div class="col-6 text-center">
                                <strong>Người sử dụng lao động</strong>
                                <p class="text-muted">(Ký, ghi rõ họ tên)</p>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>