<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_contract_list" model="ir.ui.view">
        <field name="name">contract.list</field>
        <field name="model">contract</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="contract_type_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="salary"/>
                <field name="total_salary"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_contract_form" model="ir.ui.view">
        <field name="name">contract.form</field>
        <field name="model">contract</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button string="Xác nhận"
                            name="action_confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button string="Chấm dứt hợp đồng"
                            name="action_terminate"
                            type="object"
                            class="btn-secondary"
                            invisible="state not in ('running', 'expired')"/>
                    <button string="Gia hạn hợp đồng"
                            type="action"
                            name="%(action_contract_renew_wizard)d"
                            class="btn-secondary"
                            context="{'default_contract_id': id}"
                            invisible="state not in ('running', 'expired')"/>
                    <button string="Quay lại Nháp"
                            name="action_reset_to_draft"
                            type="object"
                            icon="fa-undo"
                            invisible="state != 'running'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="code" required="1" readonly="state != 'draft'"/>
                            <field name="name" required="1" readonly="state != 'draft'"/>
                            <field name="employee_id" required="1" readonly="state != 'draft'"/>
                            <field name="contract_type_id" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="start_date" required="1" readonly="state != 'draft'"/>
                            <field name="end_date" required="1" readonly="state != 'draft'"/>
                            <field name="salary" required="1" readonly="state != 'draft'"/>
                            <field name="total_salary" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Phụ cấp">
                            <field name="allowance_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="amount"/>
                                </list>
                            </field>
                        </page>
                        <page string="Lịch sử lương">
                            <field name="salary_history_ids" readonly="1">
                                <list>
                                    <field name="salary"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_contract" model="ir.actions.act_window">
        <field name="name">Hợp đồng</field>
        <field name="res_model">contract</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>