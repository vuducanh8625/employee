<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_employee_pivot" model="ir.ui.view">
        <field name="name">employee.pivot</field>
        <field name="model">employee</field>
        <field name="arch" type="xml">
            <pivot string="Thống kê nhân viên theo phòng ban">
                <field name="department_id" type="row"/>
                <field name="salary" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_employee_graph" model="ir.ui.view">
        <field name="name">employee.graph</field>
        <field name="model">employee</field>
        <field name="arch" type="xml">
            <graph string="Thống kê nhân viên theo phòng ban" type="bar">
                <field name="department_id"/>
            </graph>
        </field>
    </record>

    <record id="action_employee_report" model="ir.actions.act_window">
        <field name="name">Thống kê nhân viên theo phòng ban</field>
        <field name="res_model">employee</field>
        <field name="view_mode">pivot,graph</field>
    </record>

</odoo>