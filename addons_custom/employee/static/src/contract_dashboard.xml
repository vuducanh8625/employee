<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="employee.ContractDashboard">
        <Layout display="display" className="'o_dashboard h-100'">
            <t t-set-slot="control-panel-navigation-buttons">
                <button class="btn btn-primary" t-on-click="openCustomers">
                    Customers
                </button>
                <button class="btn btn-secondary" t-on-click="openLeads">
                    Leads
                </button>
            </t>

            <div class="p-4 d-flex flex-wrap">

                <DashboardItem>
                    <strong>Hợp đồng mới tháng này</strong>
                    <p t-esc="statistics.nb_new_contracts"/>
                </DashboardItem>

                <DashboardItem>
                    <strong>Tổng lương hợp đồng mới tháng này</strong>
                    <p t-esc="statistics.total_salary_new"/>
                </DashboardItem>

                <DashboardItem>
                    <strong>Lương TB/hợp đồng mới tháng này</strong>
                    <p t-esc="statistics.avg_salary_new"/>
                </DashboardItem>

                <DashboardItem>
                    <strong>Hợp đồng chấm dứt/hết hạn tháng này</strong>
                    <p t-esc="statistics.nb_ended_contracts"/>
                </DashboardItem>

                <DashboardItem size="2">
                    <strong>Thời gian TB tồn tại hợp đồng (ngày)</strong>
                    <p t-esc="statistics.avg_duration_days"/>
                </DashboardItem>

                <DashboardItem size="2">
                    <strong>Tỷ lệ áo bán theo size</strong>
                    <PieChart data="tshirtData"/>
                </DashboardItem>
            </div>
        </Layout>
    </t>

</templates>